{
    "type": "function",
    "function": {
        "name": "tools_make",
        "description": "为指定 AI 创建工具描述文件，将工具的功能、参数和使用方法写入 JSON 格式的描述文件，供 AI 理解和调用",
        "parameters": {
            "type": "object",
            "properties": {
                "who": {
                    "type": "string",
                    "description": "目标 AI 的名称（信息来源方），对应 AI 文件夹名，如 'butler_ai', 'customer_ai'"
                },
                "function_name": {
                    "type": "string",
                    "description": "工具函数名，用于标识该工具，会自动去除后缀，如 'search_web', 'read_file'"
                },
                "des": {
                    "type": "object",
                    "description": "工具的结构化描述(字符串)，必须是包含外层比如type等完整的结构",
                    "properties": {
                        "name": {
                            "type": "string",
                            "description": "工具名称"
                        },
                        "description": {
                            "type": "string",
                            "description": "工具功能描述"
                        },
                        "parameters": {
                            "type": "object",
                            "description": "参数定义"
                        },
                        "returns": {
                            "type": "object",
                            "description": "返回值说明"
                        }
                    }
                }
            },
            "required": ["who", "function_name", "des"]
        }
    }
}